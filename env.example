# Copy this file to .env and fill in your own values.
# .env is git-ignored and must NEVER be committed with real secrets.

# Flask secret key, used to sign session cookies. Generate your own with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Optional: only needed if you want to use a real third-party health API
# instead of the built-in rule-based prediction engine (see app/ai_service.py).
# This project works fully offline without this key.
HEALTH_API_KEY=

# Path to the SQLite database file (relative to project root)
DATABASE_PATH=instance/health_records.db
